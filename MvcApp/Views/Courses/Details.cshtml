@model MvcApp.Models.CourseViewModel
@{
    ViewData["Title"] = "Course Details";
}

<div class="page-breadcrumb mb-2"><a href="/Courses">Courses</a> / Details</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="form-card">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div>
                    <h5 class="fw-bold mb-1">@Model.Title</h5>
                    <span class="badge @(Model.IsPublished ? "badge-published" : "badge-unpublished")">
                        @(Model.IsPublished ? "Published" : "Draft")
                    </span>
                </div>
                <span class="badge" style="background:#ede9fe;color:#7c3aed">@Model.Level</span>
            </div>

            @if (!string.IsNullOrEmpty(Model.ThumbnailPath))
            {
                <img src="http://localhost:5052@Model.ThumbnailPath" class="img-fluid rounded mb-4" style="max-height:200px;object-fit:cover" />
            }

            <p class="text-muted">@Model.Description</p>

            <table class="table table-borderless mt-3">
                <tr><th style="width:160px;color:#6b7280">Category</th><td>@Model.CategoryName</td></tr>
                <tr><th style="color:#6b7280">Instructor</th><td>@Model.InstructorName</td></tr>
                <tr><th style="color:#6b7280">Price</th><td class="fw-semibold text-success">$@Model.Price.ToString("N2")</td></tr>
                <tr><th style="color:#6b7280">Lessons</th><td>@Model.LessonsCount lessons</td></tr>
                <tr><th style="color:#6b7280">Rating</th><td>
                    <span class="stars">@string.Concat(Enumerable.Repeat("★", (int)Math.Round(Model.AverageRating)))</span>
                    @Model.AverageRating.ToString("N1")
                </td></tr>
                <tr><th style="color:#6b7280">Created</th><td>@Model.CreatedAt.ToString("MMM dd, yyyy")</td></tr>
            </table>

            <div class="d-flex gap-2 mt-3 flex-wrap">
                <a href="/Courses/Edit/@Model.Id" class="btn btn-primary btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
                <a href="/Courses/UploadThumbnail/@Model.Id" class="btn btn-light btn-sm"><i class="bi bi-image me-1"></i>Upload Thumbnail</a>
                <a href="/Lessons?courseId=@Model.Id" class="btn btn-light btn-sm"><i class="bi bi-book me-1"></i>View Lessons</a>
                <a href="/Courses" class="btn btn-light btn-sm">Back</a>
            </div>
        </div>
    </div>
</div>
