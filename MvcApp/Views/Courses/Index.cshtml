@model List<MvcApp.Models.CourseViewModel>
@{
    ViewData["Title"] = "Courses";
}

<div class="form-card mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label fw-semibold small">Search</label>
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by title..." />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold small">Category</label>
            <select name="categoryId" class="form-select" asp-items="ViewBag.Categories">
                <option value="">All Categories</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold small">Level</label>
            <select name="level" class="form-select" asp-items="ViewBag.Levels">
                <option value="">All Levels</option>
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary me-2"><i class="bi bi-search me-1"></i>Filter</button>
            <a href="/Courses" class="btn btn-light">Reset</a>
        </div>
    </form>
</div>

<div class="table-card">
    <div class="table-header">
        <h6><i class="bi bi-play-circle me-2" style="color:#4f46e5"></i>All Courses (@Model.Count)</h6>
        <a href="/Courses/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> New Course
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Image</th>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Level</th>
                    <th>Status</th>
                    <th class="pe-4 text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                @if (!string.IsNullOrEmpty(item.ThumbnailPath))
                                {
                                    <img src="http://localhost:5052@item.ThumbnailPath" class="course-thumb" alt="thumb" />
                                }
                                else
                                {
                                    <div class="course-thumb d-flex align-items-center justify-content-center" style="background:#f3f4f6">
                                        <i class="bi bi-image text-muted" style="font-size:1.2rem"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-semibold">@item.Title</div>
                                <div class="text-muted small">@item.InstructorName</div>
                            </td>
                            <td><span class="badge" style="background:#f3f4f6;color:#374151">@item.CategoryName</span></td>
                            <td class="fw-semibold text-success">$@item.Price.ToString("N2")</td>
                            <td><span class="badge" style="background:#ede9fe;color:#7c3aed">@item.Level</span></td>
                            <td>
                                @if (item.IsPublished)
                                {
                                    <span class="badge badge-published"><i class="bi bi-check-circle me-1"></i>Published</span>
                                }
                                else
                                {
                                    <span class="badge badge-unpublished"><i class="bi bi-clock me-1"></i>Draft</span>
                                }
                            </td>
                            <td class="pe-4 text-end">
                                <div class="d-flex gap-1 justify-content-end flex-wrap">
                                    <a href="/Courses/Details/@item.Id" class="btn btn-sm btn-light" title="Details"><i class="bi bi-eye"></i></a>
                                    <a href="/Courses/Edit/@item.Id" class="btn btn-sm btn-light" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Publish" asp-route-id="@item.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-light" title="Publish" style="color:#16a34a">
                                            <i class="bi bi-send"></i>
                                        </button>
                                    </form>
                                    <a href="/Courses/UploadThumbnail/@item.Id" class="btn btn-sm btn-light" title="Upload Thumbnail"><i class="bi bi-image"></i></a>
                                    <a href="/Lessons?courseId=@item.Id" class="btn btn-sm btn-light" title="Lessons"><i class="bi bi-book"></i></a>
                                    <a href="/Courses/Delete/@item.Id" class="btn btn-sm btn-light text-danger" title="Delete"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center text-muted py-5">
                        <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                        No courses found
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
