@model MvcApp.Models.UpdateLessonViewModel
@{
    ViewData["Title"] = "Edit Lesson";
    var id = ViewBag.LessonId;
    var courseId = ViewBag.CourseId;
}

<div class="page-breadcrumb mb-2"><a href="/Lessons">Lessons</a> / Edit</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="form-card">
            <h5 class="fw-bold mb-4"><i class="bi bi-pencil me-2" style="color:#4f46e5"></i>Edit Lesson</h5>
            <form asp-action="Edit" asp-route-id="@id" method="post">
                <input type="hidden" name="courseId" value="@courseId" />
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold">Title</label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Order" class="form-label fw-semibold">Order Number</label>
                    <input asp-for="Order" class="form-control" type="number" min="1" />
                </div>
                <div class="mb-4">
                    <label asp-for="Content" class="form-label fw-semibold">Content</label>
                    <textarea asp-for="Content" class="form-control" rows="5"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg me-1"></i>Save</button>
                    <a href="/Lessons?courseId=@courseId" class="btn btn-light px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
