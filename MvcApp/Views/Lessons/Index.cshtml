@model List<MvcApp.Models.LessonViewModel>
@{
    ViewData["Title"] = "Lessons";
    var selectedCourseId = ViewBag.SelectedCourseId;
}

<div class="form-card mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-6">
            <label class="form-label fw-semibold small">Select Course</label>
            <select name="courseId" class="form-select" asp-items="ViewBag.Courses">
                <option value="">-- Select a course --</option>
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i>Load Lessons</button>
        </div>
    </form>
</div>

<div class="table-card">
    <div class="table-header">
        <h6><i class="bi bi-book me-2" style="color:#4f46e5"></i>Lessons (@Model.Count)</h6>
        @if (selectedCourseId != null)
        {
            <a href="/Lessons/Create?courseId=@selectedCourseId" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i> New Lesson
            </a>
        }
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Order</th>
                    <th>Title</th>
                    <th>Content Preview</th>
                    <th class="pe-4 text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="badge" style="background:#ede9fe;color:#7c3aed">#@item.Order</span>
                            </td>
                            <td class="fw-semibold">@item.Title</td>
                            <td class="text-muted">@(item.Content?.Length > 60 ? item.Content.Substring(0, 60) + "..." : item.Content ?? "—")</td>
                            <td class="pe-4 text-end">
                                <a href="/Lessons/Details/@item.Id" class="btn btn-sm btn-light me-1" title="Details"><i class="bi bi-eye"></i></a>
                                <a href="/Lessons/Edit/@item.Id" class="btn btn-sm btn-light me-1" title="Edit"><i class="bi bi-pencil"></i></a>
                                <a href="/Lessons/Delete/@item.Id" class="btn btn-sm btn-light text-danger" title="Delete"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                }
                else if (selectedCourseId != null)
                {
                    <tr><td colspan="4" class="text-center text-muted py-5">
                        <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                        No lessons found for this course
                    </td></tr>
                }
                else
                {
                    <tr><td colspan="4" class="text-center text-muted py-5">
                        <i class="bi bi-arrow-up-circle" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                        Select a course to view its lessons
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
