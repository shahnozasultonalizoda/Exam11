@model MvcApp.Models.LessonViewModel
@{
    ViewData["Title"] = "Lesson Details";
}

<div class="page-breadcrumb mb-2"><a href="/Lessons">Lessons</a> / Details</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="form-card">
            <div class="d-flex justify-content-between mb-4">
                <h5 class="fw-bold mb-0">@Model.Title</h5>
                <span class="badge" style="background:#ede9fe;color:#7c3aed">Order: @Model.Order</span>
            </div>
            <table class="table table-borderless">
                <tr><th style="width:120px;color:#6b7280">Course</th><td>@Model.CourseName</td></tr>
                <tr><th style="color:#6b7280">Content</th><td>@(Model.Content ?? "—")</td></tr>
            </table>
            <div class="d-flex gap-2 mt-3">
                <a href="/Lessons/Edit/@Model.Id" class="btn btn-primary btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
                <a href="/Lessons?courseId=@Model.CourseId" class="btn btn-light btn-sm">Back</a>
            </div>
        </div>
    </div>
</div>
