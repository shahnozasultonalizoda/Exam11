@model MvcApp.Models.CreateLessonViewModel
@{
    ViewData["Title"] = "Create Lesson";
}

<div class="page-breadcrumb mb-2"><a href="/Lessons">Lessons</a> / Create</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="form-card">
            <h5 class="fw-bold mb-4"><i class="bi bi-plus-circle me-2" style="color:#4f46e5"></i>New Lesson</h5>
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label asp-for="CourseId" class="form-label fw-semibold">Course <span class="text-danger">*</span></label>
                    <select asp-for="CourseId" class="form-select" asp-items="ViewBag.Courses">
                        <option value="">Select course</option>
                    </select>
                    <span asp-validation-for="CourseId" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" placeholder="Lesson title" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Order" class="form-label fw-semibold">Order Number</label>
                    <input asp-for="Order" class="form-control" type="number" min="1" />
                </div>
                <div class="mb-4">
                    <label asp-for="Content" class="form-label fw-semibold">Content</label>
                    <textarea asp-for="Content" class="form-control" rows="5" placeholder="Lesson content..."></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg me-1"></i>Create</button>
                    <a href="/Lessons" class="btn btn-light px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
