@model MvcApp.Models.UpdateRoleViewModel
@{
    ViewData["Title"] = "Edit User Role";
}

<div class="page-breadcrumb mb-2"><a href="/Users">Users</a> / Edit Role</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="form-card">
            <h5 class="fw-bold mb-4"><i class="bi bi-shield me-2" style="color:#4f46e5"></i>Change User Role</h5>
            <div class="d-flex align-items-center gap-3 p-3 mb-4" style="background:#f8fafc;border-radius:10px">
                <div style="width:48px;height:48px;border-radius:50%;background:#ede9fe;display:flex;align-items:center;justify-content:center;color:#7c3aed;font-weight:700;font-size:1.2rem">
                    @Model.FullName[0].ToString().ToUpper()
                </div>
                <div>
                    <div class="fw-semibold">@Model.FullName</div>
                    <div class="text-muted small">@Model.Email</div>
                </div>
            </div>
            <form asp-action="EditRole" asp-route-id="@Model.Id" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="FullName" />
                <input type="hidden" asp-for="Email" />
                <div class="mb-4">
                    <label asp-for="Role" class="form-label fw-semibold">Select New Role</label>
                    <select asp-for="Role" class="form-select" asp-items="ViewBag.Roles"></select>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg me-1"></i>Update Role</button>
                    <a href="/Users" class="btn btn-light px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
