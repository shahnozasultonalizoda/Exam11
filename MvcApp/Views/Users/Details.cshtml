@model MvcApp.Models.UserViewModel
@{
    ViewData["Title"] = "User Details";
}

<div class="page-breadcrumb mb-2"><a href="/Users">Users</a> / Details</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="form-card">
            <div class="text-center mb-4">
                <div style="width:72px;height:72px;border-radius:50%;background:#ede9fe;display:flex;align-items:center;justify-content:center;color:#7c3aed;font-weight:700;font-size:1.8rem;margin:0 auto 12px">
                    @Model.FullName[0].ToString().ToUpper()
                </div>
                <h5 class="fw-bold mb-1">@Model.FullName</h5>
                <span class="badge" style="background:#ede9fe;color:#7c3aed">@Model.Role</span>
            </div>
            <table class="table table-borderless">
                <tr><th style="width:120px;color:#6b7280">ID</th><td>#@Model.Id</td></tr>
                <tr><th style="color:#6b7280">Email</th><td>@Model.Email</td></tr>
                <tr><th style="color:#6b7280">Role</th><td>@Model.Role</td></tr>
                <tr><th style="color:#6b7280">Joined</th><td>@Model.CreatedAt.ToString("MMMM dd, yyyy")</td></tr>
            </table>
            <div class="d-flex gap-2 mt-3">
                <a href="/Users/EditRole/@Model.Id" class="btn btn-primary btn-sm"><i class="bi bi-shield me-1"></i>Edit Role</a>
                <a href="/Users" class="btn btn-light btn-sm">Back</a>
            </div>
        </div>
    </div>
</div>
