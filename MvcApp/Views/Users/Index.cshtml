@model List<MvcApp.Models.UserViewModel>
@{
    ViewData["Title"] = "Users";
}

<div class="table-card">
    <div class="table-header">
        <h6><i class="bi bi-people me-2" style="color:#4f46e5"></i>All Users (@Model.Count)</h6>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">#</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Joined</th>
                    <th class="pe-4 text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 text-muted">@item.Id</td>
                        <td class="fw-semibold">
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:32px;height:32px;border-radius:50%;background:#ede9fe;display:flex;align-items:center;justify-content:center;color:#7c3aed;font-weight:700;font-size:0.8rem">
                                    @item.FullName[0].ToString().ToUpper()
                                </div>
                                @item.FullName
                            </div>
                        </td>
                        <td class="text-muted">@item.Email</td>
                        <td>
                            @{
                                var roleColor = item.Role switch
                                {
                                    "Admin" => "background:#fee2e2;color:#dc2626",
                                    "Instructor" => "background:#fef3c7;color:#d97706",
                                    _ => "background:#dcfce7;color:#16a34a"
                                };
                            }
                            <span class="badge" style="@roleColor">@item.Role</span>
                        </td>
                        <td class="text-muted small">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td class="pe-4 text-end">
                            <a href="/Users/Details/@item.Id" class="btn btn-sm btn-light me-1" title="Details"><i class="bi bi-eye"></i></a>
                            <a href="/Users/EditRole/@item.Id" class="btn btn-sm btn-light me-1" title="Edit Role"><i class="bi bi-shield"></i></a>
                            <form asp-controller="Users" asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this user?')">
                                <button type="submit" class="btn btn-sm btn-light text-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
