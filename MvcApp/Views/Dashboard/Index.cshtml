@model MvcApp.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="icon" style="background:#ede9fe">📚</div>
            <div class="value">@Model.TotalCourses</div>
            <div class="label">Total Courses</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="icon" style="background:#dcfce7">👥</div>
            <div class="value">@Model.TotalStudents</div>
            <div class="label">Total Students</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="icon" style="background:#fef3c7">📝</div>
            <div class="value">@Model.TotalEnrollments</div>
            <div class="label">Total Enrollments</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="icon" style="background:#fee2e2">💰</div>
            <div class="value">$@Model.TotalRevenue.ToString("N0")</div>
            <div class="label">Total Revenue</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="table-card">
            <div class="table-header">
                <h6><i class="bi bi-trophy me-2" style="color:#f59e0b"></i>Top Courses</h6>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Course Title</th>
                            <th>Enrollments</th>
                            <th class="pe-4">Progress</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.TopCourses.Any())
                        {
                            @for (int i = 0; i < Model.TopCourses.Count; i++)
                            {
                                var course = Model.TopCourses[i];
                                var pct = Model.TotalEnrollments > 0 ? (int)((double)course.EnrollmentsCount / Model.TotalEnrollments * 100) : 0;
                                <tr>
                                    <td class="ps-4 text-muted">@(i + 1)</td>
                                    <td class="fw-semibold">@course.Title</td>
                                    <td><span class="badge" style="background:#ede9fe;color:#7c3aed">@course.EnrollmentsCount students</span></td>
                                    <td class="pe-4" style="min-width:120px">
                                        <div class="progress">
                                            <div class="progress-bar" style="width:@pct%;background:#4f46e5"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-center text-muted py-4">No data available</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="table-card h-100">
            <div class="table-header">
                <h6><i class="bi bi-lightning-charge me-2" style="color:#4f46e5"></i>Quick Actions</h6>
            </div>
            <div class="p-4 d-flex flex-column gap-3">
                <a href="/Categories/Create" class="btn btn-sm text-start d-flex align-items-center gap-2" style="background:#ede9fe;color:#7c3aed;border:none;padding:12px 16px;border-radius:8px">
                    <i class="bi bi-plus-circle"></i> Add Category
                </a>
                <a href="/Courses/Create" class="btn btn-sm text-start d-flex align-items-center gap-2" style="background:#dcfce7;color:#16a34a;border:none;padding:12px 16px;border-radius:8px">
                    <i class="bi bi-plus-circle"></i> Add Course
                </a>
                <a href="/Lessons/Create" class="btn btn-sm text-start d-flex align-items-center gap-2" style="background:#fef3c7;color:#d97706;border:none;padding:12px 16px;border-radius:8px">
                    <i class="bi bi-plus-circle"></i> Add Lesson
                </a>
                <a href="/Users" class="btn btn-sm text-start d-flex align-items-center gap-2" style="background:#fee2e2;color:#dc2626;border:none;padding:12px 16px;border-radius:8px">
                    <i class="bi bi-people"></i> Manage Users
                </a>
            </div>
        </div>
    </div>
</div>
