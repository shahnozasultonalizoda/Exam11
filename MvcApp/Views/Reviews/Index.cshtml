@model List<MvcApp.Models.ReviewViewModel>
@{
    ViewData["Title"] = "Reviews";
    var selectedCourseId = ViewBag.SelectedCourseId;
}

<div class="form-card mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label fw-semibold small">Select Course</label>
            <select name="courseId" class="form-select" asp-items="ViewBag.Courses">
                <option value="">-- Select a course --</option>
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i>Load Reviews</button>
        </div>
    </form>
</div>

<div class="table-card">
    <div class="table-header">
        <h6><i class="bi bi-star me-2" style="color:#f59e0b"></i>Reviews (@Model.Count)</h6>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Rating</th>
                    <th>Comment</th>
                    <th>Student ID</th>
                    <th>Created At</th>
                    <th class="pe-4 text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="stars">@string.Concat(Enumerable.Repeat("★", item.Rating))</span>
                                <span class="text-muted ms-1">@item.Rating/5</span>
                            </td>
                            <td>@(item.Comment.Length > 80 ? item.Comment.Substring(0, 80) + "..." : item.Comment)</td>
                            <td class="text-muted">#@item.StudentId</td>
                            <td class="text-muted small">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="pe-4 text-end">
                                <form asp-controller="Reviews" asp-action="Delete" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this review?')">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="courseId" value="@selectedCourseId" />
                                    <button type="submit" class="btn btn-sm btn-light text-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else if (selectedCourseId != null)
                {
                    <tr><td colspan="5" class="text-center text-muted py-5">
                        <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                        No reviews found for this course
                    </td></tr>
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted py-5">
                        <i class="bi bi-arrow-up-circle" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                        Select a course to view its reviews
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
