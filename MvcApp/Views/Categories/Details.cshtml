@model MvcApp.Models.CategoryViewModel
@{
    ViewData["Title"] = "Category Details";
}

<div class="page-breadcrumb mb-2">
    <a href="/Categories">Categories</a> / Details
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="form-card">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <h5 class="fw-bold mb-0"><i class="bi bi-tag me-2" style="color:#4f46e5"></i>@Model.Name</h5>
                <span class="badge" style="background:#ede9fe;color:#7c3aed">ID: @Model.Id</span>
            </div>
            <table class="table table-borderless">
                <tr><th style="width:140px;color:#6b7280">Name</th><td class="fw-semibold">@Model.Name</td></tr>
                <tr><th style="color:#6b7280">Description</th><td>@(Model.Description ?? "—")</td></tr>
            </table>
            <div class="d-flex gap-2 mt-3">
                <a href="/Categories/Edit/@Model.Id" class="btn btn-primary btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
                <a href="/Categories" class="btn btn-light btn-sm">Back</a>
            </div>
        </div>
    </div>
</div>
