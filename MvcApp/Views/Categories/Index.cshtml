@model List<MvcApp.Models.CategoryViewModel>
@{
    ViewData["Title"] = "Categories";
}

<div class="table-card">
    <div class="table-header">
        <h6><i class="bi bi-tag me-2" style="color:#4f46e5"></i>All Categories (@Model.Count)</h6>
        <a href="/Categories/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> New Category
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">#</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th class="pe-4 text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">@item.Id</td>
                            <td class="fw-semibold">@item.Name</td>
                            <td class="text-muted">@(item.Description ?? "—")</td>
                            <td class="pe-4 text-end">
                                <a href="/Categories/Details/@item.Id" class="btn btn-sm btn-light me-1" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="/Categories/Edit/@item.Id" class="btn btn-sm btn-light me-1" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/Categories/Delete/@item.Id" class="btn btn-sm btn-light text-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="4" class="text-center text-muted py-5">
                        <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                        No categories found
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
