@model MvcApp.Models.CategoryViewModel
@{
    ViewData["Title"] = "Delete Category";
}

<div class="page-breadcrumb mb-2">
    <a href="/Categories">Categories</a> / Delete
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="form-card border-danger">
            <div class="text-center mb-4">
                <div style="font-size:3rem;color:#dc2626"><i class="bi bi-exclamation-triangle-fill"></i></div>
                <h5 class="fw-bold mt-2">Delete Category</h5>
                <p class="text-muted">Are you sure you want to delete <strong>@Model.Name</strong>? This action cannot be undone.</p>
            </div>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                <div class="d-flex gap-2 justify-content-center">
                    <button type="submit" class="btn btn-danger px-4"><i class="bi bi-trash me-1"></i>Yes, Delete</button>
                    <a href="/Categories" class="btn btn-light px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
